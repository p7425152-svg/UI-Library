-- ฟังก์ชันสร้าง Toggle
local function CreateToggle(text, yPos, toggleName)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(0.9, 0, 0, 50)
    Btn.Position = UDim2.new(0.05, 0, 0, yPos)
    Btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Btn.Text = text .. ": ON"
    Btn.TextColor3 = Color3.new(1,1,1)
    Btn.TextScaled = true
    Btn.Font = Enum.Font.GothamSemibold
    Btn.Parent = MainFrame

    Btn.MouseButton1Click:Connect(function()
        _G[toggleName] = not _G[toggleName]
        Btn.Text = text .. (_G[toggleName] and ": ON" or ": OFF")
        Btn.BackgroundColor3 = _G[toggleName] and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(170, 0, 0)
    end)
end

-- สร้างปุ่มต่าง ๆ
CreateToggle("Auto ATM", 130, "AutoATM")
CreateToggle("Auto Plant", 190, "AutoPlant")
CreateToggle("Auto Harvest", 250, "AutoHarvest")
CreateToggle("Auto Deposit", 310, "AutoDeposit")

-- ปุ่มเปิด-ปิดหลัก
local MainToggle = Instance.new("TextButton")
MainToggle.Size = UDim2.new(0.9, 0, 0, 55)
MainToggle.Position = UDim2.new(0.05, 0, 0, 375)
MainToggle.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
