local function ToggleBtn(name, y, var)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9,0,0,50)
    btn.Position = UDim2.new(0.05,0,0,y)
    btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    btn.Text = name .. ": ON"
    btn.TextColor3 = Color3.new(1,1,1)
    btn.TextScaled = true
    btn.Font = Enum.Font.GothamSemibold
    btn.Parent = frame

    btn.MouseButton1Click:Connect(function()
        _G[var] = not _G[var]
        btn.Text = name .. (_G[var] and ": ON" or ": OFF")
        btn.BackgroundColor3 = _G[var] and Color3.fromRGB(0,170,0) or Color3.fromRGB(170,0,0)
    end)
end

ToggleBtn("Auto ATM Hack", 130, "AutoATM")
ToggleBtn("Auto Plant", 190, "AutoPlant")
ToggleBtn("Auto Harvest", 250, "AutoHarvest")
ToggleBtn("Auto Deposit", 310, "AutoDeposit")
ToggleBtn("Auto Stocking", 370, "AutoStock")

