-- ================== ระบบฟาร์ม ==================
spawn(function()
    while true do
        if _G.AutoFarm then
            pcall(function()
                -- Auto ATM
                if _G.AutoATM then
                    for _, v in ipairs(workspace:GetDescendants()) do
                        if v.Name:lower():find("atm") or v.Name:lower():find("teller") then
                            local remote = rs:FindFirstChild("ATMEvent", true) or rs.Remotes:FindFirstChild("ATMEvent")
                            if remote then remote:FireServer("Hack", v) end
                        end
                    end
                end

                -- Auto Plant
                if _G.AutoPlant then
                    local plots = workspace:FindFirstChild("Houses") or workspace:FindFirstChild("Plots") or workspace
                    for _, p in ipairs(plots:GetDescendants()) do
                        if p:FindFirstChild("Soil") and not p:FindFirstChild("Plant") and not p:FindFirstChild("Tree") then
                            local r = rs.Remotes:FindFirstChild("PlantSeed") or rs:FindFirstChild("PlantSeed", true)
                            if r then r:FireServer("Sunflower", p) end
                        end
                    end
                end

                -- Auto Harvest
                if _G.AutoHarvest then
                    for _, obj in ipairs(workspace:GetDescendants()) do
                        if obj.Name:lower():find("sunflower") or obj.Name:lower():find("tree") or obj.Name:lower():find("plant") then
                            local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt")
                            if prompt then fireproximityprompt(prompt) end
                        end
                    end
                end

                -- Auto Deposit
                if _G.AutoDeposit then
                    local money = player.leaderstats and player.leaderstats:FindFirstChild("Money")
                    if money and money.Value >= _G.DepositAt then
                        local r = rs:FindFirstChild("ATMEvent", true) or rs.Remotes:FindFirstChild("ATMEvent")
                        if r then r:FireServer({Action = "Deposit", Amount = "All"}) end
                    end
                end
            end)
        end
        task.wait(1.5)
    end
end)

